# ── 认证配置 ──────────────────────────────
JWT_SECRET=请替换为随机长字符串
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── AI 配置（管理员可在界面修改，.env 仅作 fallback）──
ENABLE_AI=true
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-...

# 国产模型 / 中转站：设置 LLM_BASE_URL 即可，LLM_PROVIDER 保持 openai
# Kimi (月之暗面):  LLM_BASE_URL=https://api.moonshot.cn/v1
#                   LLM_MODEL=moonshot-v1-8k
# DeepSeek:         LLM_BASE_URL=https://api.deepseek.com/v1
#                   LLM_MODEL=deepseek-chat
# Qwen (阿里云):    LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#                   LLM_MODEL=qwen-max
# 豆包 (字节):      LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
#                   LLM_MODEL=<你的推理接入点 endpoint-id>
# MiniMax:          LLM_BASE_URL=https://api.minimax.chat/v1
#                   LLM_MODEL=abab6.5s-chat
# 智谱 GLM:         LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#                   LLM_MODEL=glm-4-flash
# SiliconFlow 中转: LLM_BASE_URL=https://api.siliconflow.cn/v1
#                   LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# LLM_BASE_URL=

# Ollama 本地模型
OLLAMA_BASE_URL=http://localhost:11434
